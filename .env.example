# Copy this file to .env for local testing — never commit the real .env file
# On Render, set this as an Environment Variable in the dashboard instead

GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated list of domains allowed to call this backend
# e.g. https://your-examgo-site.netlify.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
